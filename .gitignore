# Icon cache (generated at runtime from FFXI DAT files)
cache/

# User settings (generated per-character). Don't blanket-exclude data/
# because we also ship static lookup tables there; instead enumerate the
# runtime-generated patterns explicitly.
data/settings.xml
data/*_settings.xml
data/Kalitzo*
data/*-character.json

# Backups
backup/
backup_old/

# Editor swap/temp files
*.swp
*.swo
*~
*.bak

# OS files
Thumbs.db
Desktop.ini
.DS_Store
